# PaceRunner — variables d'environnement (exemple).
# Copier en `.env` (non commité) : cp .env.example .env

ENVIRONMENT=dev

# Sécurité API — token Bearer attendu sur les endpoints protégés (cf. D4)
API_TOKEN=change-me

# LLM — API OpenAI-compatible. Choisis UN moteur :
#  (A) LOCAL Ollama (défaut, aucune clé) :
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_API_KEY=
#  (B) HF Inference (commenter (A), décommenter ci-dessous, mettre ton token HF) :
# LLM_BASE_URL=https://router.huggingface.co/v1
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# LLM_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# COROS — OAuth (app mono-utilisateur) : client public DCR + refresh token
COROS_CLIENT_ID=
COROS_REFRESH_TOKEN=

# Base de données — Neon Postgres (asyncpg)
DATABASE_URL=

# Carte du tracé (front) — token Mapbox gratuit pour fond relief/satellite (optionnel)
MAPBOX_TOKEN=
